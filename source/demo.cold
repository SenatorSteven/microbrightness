#define SETBRIGHTNESS() /*-*/ local void setBrightness(double brightness, const int whichMonitor)

SETBRIGHTNESS();

SETBRIGHTNESS(){
	Monitor *monitorCurrent = monitorStart;
	Monitor *wall = monitorWall;
	if(brightness > 1.0){
		brightness = 1.0;
	}elif(brightness < 0.0){
		brightness = 0.0;
	}
	if(whichMonitor > -1){
		monitorCurrent += whichMonitor;
		wall = monitorCurrent + 1;
	}



	/*! fixme: get the current monitor brightness and if smaller than the one we want to impose then noop else change brightness */



	while(monitorCurrent < wall){
		Crtc *crtcCurrent = (*monitorCurrent).crtcStart;
		Crtc *crtcWall = crtcCurrent + (*monitorCurrent).crtcAllocated;
		if(!crtcCurrent){
			jmp iterateCRTCLoopControl;
		}
		jmp iterateCRTCLoop;
		iterateCRTCLoop:{
			const double gammaSize = (*crtcCurrent).gammaSize;
			uint16 *red   = (*crtcCurrent).red;
			uint16 *green = (*crtcCurrent).green;
			uint16 *blue  = (*crtcCurrent).blue;
			const double gammaMinusOne = gammaSize - 1;
			double currentGamma = 0.0;
			if((*crtcCurrent).redGamma == (*crtcCurrent).greenGamma and (*crtcCurrent).greenGamma == (*crtcCurrent).blueGamma){
				jmp updateCRTCBrightness0Loop;
				updateCRTCBrightness0Loop:{
					*red = min(pow(currentGamma / gammaMinusOne, (*crtcCurrent).redGamma) * brightness, 1.0) * 65535;
					*green = *red;
					*blue = *green;
					if(inc currentGamma < gammaSize){
						inc red;
						inc green;
						inc blue;
						jmp updateCRTCBrightness0Loop;
					}
				}
			}else{
				jmp updateCRTCBrightness1Loop;
				updateCRTCBrightness1Loop:{
					const double value = currentGamma / gammaMinusOne;
					*red   = min(pow(value, (*crtcCurrent).redGamma  ) * brightness, 1.0) * 65535;
					*green = min(pow(value, (*crtcCurrent).greenGamma) * brightness, 1.0) * 65535;
					*blue  = min(pow(value, (*crtcCurrent).blueGamma ) * brightness, 1.0) * 65535;
					if(inc currentGamma < gammaSize){
						inc red;
						inc green;
						inc blue;
						jmp updateCRTCBrightness1Loop;
					}
				}
			}
			xcb_randr_set_crtc_gamma(connection, (*crtcCurrent).crtc, (*crtcCurrent).gammaSize, (*crtcCurrent).red, (*crtcCurrent).green, (*crtcCurrent).blue);
			xcb_flush(connection);
			jmp iterateCRTCLoopControl;
		}
		iterateCRTCLoopControl:{
			if(inc crtcCurrent < crtcWall){
				jmp iterateCRTCLoop;
			}
		}
		inc monitorCurrent;
	}
	ret;
}









local double timeLength = 1.00;
local uint frames       = 100;
local int whichMonitor  = -1;

int main(void){
	if(geteuid()){
		fprintf(stderr, "program is not executed as super user and therefore cannot suspend\n");
	}
	connection = xcb_connect(NULL, NULL);
	if(xcb_connection_has_error(connection)){
		fprintf(stderr, "unable to connect to the X server\n");
		ret 1;
	}
	screen = xcb_setup_roots_iterator(xcb_get_setup(connection)).data;



	if(!storeMonitors()){
		fprintf(stdout, "could not store monitors\n");
		ret 1;
	}
	if(!getMonitorGamma()){
		fprintf(stdout, "could not get monitor gamma\n");
		ret 1;
	}









	xcb_randr_select_input(connection, (*screen).root, XCB_RANDR_NOTIFY_MASK_SCREEN_CHANGE | XCB_RANDR_NOTIFY_MASK_CRTC_CHANGE | XCB_RANDR_NOTIFY_MASK_OUTPUT_CHANGE | XCB_RANDR_NOTIFY_MASK_OUTPUT_PROPERTY | XCB_RANDR_NOTIFY_MASK_PROVIDER_CHANGE | XCB_RANDR_NOTIFY_MASK_PROVIDER_PROPERTY | XCB_RANDR_NOTIFY_MASK_RESOURCE_CHANGE | XCB_RANDR_NOTIFY_MASK_LEASE);









	if(frames){
		const int64 nanoTimeLength = (int64)(timeLength * 100) * 10000000 / frames;
		const double step = 1.00 / frames;
		double currentBrightness = 1.0;
		struct timespec t0;
		struct timespec t1;
		int64 realNanoTimeLength;
		uint currentFrame = 0;
		inc frames;
		fadeOutLoop:{
			clock_gettime(CLOCK_MONOTONIC_RAW, &t0);
			setBrightness(currentBrightness, whichMonitor);
			if(inc currentFrame < frames){
				currentBrightness -= step;
				realNanoTimeLength = nanoTimeLength;
				clock_gettime(CLOCK_MONOTONIC_RAW, &t1);
				realNanoTimeLength -= (t1.tv_sec - t0.tv_sec) * 1000000000 + t1.tv_nsec - t0.tv_nsec;
				t0.tv_sec = realNanoTimeLength / 1000000000;
				t0.tv_nsec = realNanoTimeLength - t0.tv_sec * 1000000000;
				nanosleep(&t0, NULL);
				jmp fadeOutLoop;
			}
		}



		t0.tv_sec = 0;
		t0.tv_nsec = 250000000;
		nanosleep(&t0, NULL);
	}else{
		struct timespec t0;
		setBrightness(0.0, whichMonitor);
		t0.tv_sec = 0;
		t0.tv_nsec = 250000000;
		nanosleep(&t0, NULL);
	}
	{
		struct timespec t0;
		setBrightness(1.0, whichMonitor);
		t0.tv_sec = 0;
		t0.tv_nsec = 250000000;
		nanosleep(&t0, NULL);
	}









#ifdef a
	{
		const char *const eventName[] = {"error", "unrecognized", "key press", "key release", "button press", "button release", "motion notify", "enter notify", "leave notify", "focus in", "focus out", "keymap notify", "expose", "graphics expose", "no expose", "visibility notify", "create notify", "destroy notify", "unmap notify", "map notify", "map request", "reparent notify", "configure notify", "configure request", "gravity notify", "resize request", "circulate notify", "circulate request", "property notify", "selection clear", "selection request", "selection notify", "colormap notify", "client message", "mapping notify", "generic event"};

#define MONITOR_DATA_SIZE /*-------------*/ (4)
#define OUTPUT_DATA_SIZE /*--------------*/ (4)
#define CRTC_DATA_SIZE /*----------------*/ (8)

#define STOREMONITORS() /*---------------*/ local bool storeMonitors(void)
#define GETMONITORGAMMA() /*-------------*/ local bool getMonitorGamma(void)

#define xcb_wait_for_reply(a, b, c) /*---*/ (xcb_wait_for_reply(a, (b).sequence, c))
#define xcb_send_event(a, b, c, d, e) /*-*/ (xcb_send_event(a, b, c, d, (void *)(e)))

def struct{
	void * /*-----------*/ data;
	uint16 * /*---------*/ red;
	uint16 * /*---------*/ green;
	uint16 * /*---------*/ blue;
	double /*-----------*/ brightness;
	double /*-----------*/ redGamma;
	double /*-----------*/ greenGamma;
	double /*-----------*/ blueGamma;
	xcb_randr_crtc_t /*-*/ crtc;
	uint32 /*-----------*/ gammaSize;
} Crtc;

def struct{
	Crtc * /*-----------*/ crtcStart;
	uint32 /*-----------*/ crtcAllocated;
	uint32 /*-----------*/ crtcSize;
} Monitor;

local xcb_connection_t * /*-*/ connection;
local xcb_screen_t * /*-----*/ screen;

local Monitor * /*----------*/ monitorStart;
local Monitor * /*----------*/ monitorWall;
local uint /*---------------*/ monitorAllocated;

STOREMONITORS();
GETMONITORGAMMA();

local uint findNonClamped(const uint16 *arrayCurrent, int size){
	const uint16 *const arrayStart = arrayCurrent - size;
	while(dec arrayCurrent >= arrayStart){
		if(*arrayCurrent < 65535){
			ret arrayCurrent - arrayStart;
		}
	}
	ret 1;
}
local double round(double number){
	double doubleNumber;
	number *= 100;
	doubleNumber = (int)number;
	ret doubleNumber / 100 + (number - doubleNumber >= 0.5) * 0.01;
}
local double min(double x, double y){
	if(x < y){
		ret x;
	}
	ret y;
}









#ifdef a

	uint32 /*----------*/ background;



	xcb_colormap_t /*-------*/ colormap;
	xVisual /*--------------*/ visual;
	xDepth /*---------------*/ depth;



	const char name[] = "brightness";



	bool received;



	const uint32 stackMode = XCB_STACK_MODE_ABOVE;



	Texture base;



	#undef  xWindow




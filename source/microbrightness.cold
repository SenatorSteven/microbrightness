/*!}*/









#define QUIT_DEC /*----------*/ local void quit(const int signal)
#define LITERAL_LENGTH(l) /*-*/ (sizeof(l) - 1)



QUIT_DEC;



QUIT_DEC{
	if(signal != SIGUSR1){
		printError("ignoring received signal, not SIGUSR1");
		ret;
	}
	received = true;
	xcb_configure_window(connection, window, XCB_CONFIG_WINDOW_STACK_MODE, &stackMode);
	xcb_map_window(connection, window);
	xcb_flush(connection);
	ret;
}









#define LOADTEXTURE_DEC /*---------------------*/ Texture loadTexture(const char *const path)



LOADTEXTURE_DEC;



/*!
	optimize this
*/
LOADTEXTURE_DEC{
	Texture texture;
	FILE *file;
	uint offset;
	uint8 data[26];
	if(!(file = fopen(path, "rb"))){
		printError("could not open texture file");
		jmp retFailure;
	}
	if(fread(data, 1, 26, file) != 26){
		printError("could not read texture file data");
		jmp retFailure;
	}
	if(*data != 'B' or *(data + 1) != 'M'){
		printError("texture file is not bitmap");
		jmp retFailure;
	}
	offset         = *(uint32 *)(data + 10);
	texture.width  = *(uint32 *)(data + 18);
	texture.height = *(uint32 *)(data + 22);
	texture.size   = *(uint32 *)(data +  2) - offset;
	fseek(file, offset, SEEK_SET);
	if(!(texture.data = malloc(texture.size * sizeof(uint8)))){
		printError("texture file is not bitmap");
		jmp retFailure;
	}
	{
		const uint width = texture.width * 4;
		uint8 *start = texture.data;
		uint8 *current = start + texture.size - width;
		readRowLoop:{
			if(fread(current, 1, width, file) != width){
				printError("could not read texture file data");
				jmp retFailure;
			}
			if((current -= width) >= start){
				jmp readRowLoop;
			}
		}
	}
	fclose(file);
	file = NULL;
	ret texture;
	retFailure:{
		texture.width  = 0;
		texture.height = 0;
		texture.size   = 0;
		texture.data   = NULL;
		ret texture;
	}
}









/*!
	optimize this
*/
void applyTexture(Texture source, Texture destination){
	uint sourceY;
	uint sourceYWall;
	uint destinationY;
	uint destinationYWall;
	if(source.x > destination.width or source.y > destination.height){
		ret;
	}



	sourceY          = 0;
	sourceYWall      = source.height;
	destinationY     = source.y;
	destinationYWall = destination.height;



	yLoop:{
		if(sourceY < sourceYWall and destinationY < destinationYWall){



			uint sourceX          = 0;
			uint sourceXWall      = source.width;
			uint destinationX     = source.x;
			uint destinationXWall = destination.width;



			xLoop:{
				if(sourceX < sourceXWall and destinationX < destinationXWall){



					const uint32 *const s = (uint32 *)     source.data +      sourceY *      source.width + sourceX;
					      uint32 *const d = (uint32 *)destination.data + destinationY * destination.width + destinationX;



					const uint32 sA = *s >> 24;
					if(sA == 255){
						*d = *s;
					}elif(sA){
						const uint32 dA = (255 - sA) * (*d >> 24) / 255;
						const uint32 a = sA + dA;
						const uint32 r = ((*s <<  8) >> 24) * sA + ((*d <<  8) >> 24) * dA;
						const uint32 g = ((*s << 16) >> 24) * sA + ((*d << 16) >> 24) * dA;
						const uint32 b = ((*s << 24) >> 24) * sA + ((*d << 24) >> 24) * dA;
						*d = (a << 24) + ((r / a) << 16) + ((g / a) << 8) + (b / a);
					}



					inc sourceX;
					inc destinationX;
					jmp xLoop;
				}
			}



			inc sourceY;
			inc destinationY;
			jmp yLoop;
		}
	}
	ret;
}









int main(const int argumentAmount, const char *const *argument){
	jmp main;









	main:{
		(void)argumentAmount;



		width  = 300;
		height = 300;
		x      = (1920 - width ) / 2;
		y      = (1080 - height) / 2 + height;



		duration = 2;
		received = false;



		foreground = 0xFFFFFFFF;
		background = 0xFF000000;



		base = loadTexture("/home/steven/Documents/microbrightness/assets/wallpaper.bmp");
		{
			Texture brightness = loadTexture("/home/steven/Documents/microbrightness/assets/brightness.bmp");
			{
				const uint xPercent = 50;
				const uint yPercent = 30;
				brightness.x = (base.width  - brightness.width ) * xPercent / 100;
				brightness.y = (base.height - brightness.height) * yPercent / 100;
				applyTexture(brightness, base);
			}
			free(brightness.data);
		}









		jmp setPrimaryGlobals;
	}









	setPrimaryGlobals:{
		programName /*---------*/ = *argument;
		errorPath /*-----------*/ = NULL;
		connectionName /*------*/ = NULL;
		mustOpenErrorStream /*-*/ = false;
		errorStream /*---------*/ = DefaultErrorStream;
		connection /*----------*/ = NULL;
		genericError /*--------*/ = NULL;
		event /*---------------*/ = NULL;
		agp0 /*----------------*/ = NULL;
		quitMessage /*---------*/ = NULL;
		jmp establishServerConnection;
	}









	establishServerConnection:{
		#define ESTABLISHSERVERCONNECTION_CONNECTION /*-----*/ connection
		#define ESTABLISHSERVERCONNECTION_CONNECTIONNAME /*-*/ connectionName
		#define ESTABLISHSERVERCONNECTION_SCREEN /*---------*/ screen
		#include "xcb/establishServerConnection.hold"
		switch xcb_connection_has_error(connection) over
			to XCB_NONE: /*------------*/ /*-----------------------------------------------------------------*/ jmp generateIDs;
			to XCB_CONN_CLOSED_PARSE_ERR: printError(connectionName? "invalid server name" : "no server name"); jmp mainEmergencyExit;
			off: /*--------------------*/ printConnectionError(); /*-----------------------------------------*/ jmp mainEmergencyExit;
		end
	}









	generateIDs:{
		font /*-----*/ = xcb_generate_id(connection);
		gc /*-------*/ = xcb_generate_id(connection);
		window /*---*/ = xcb_generate_id(connection);
		colormap /*-*/ = xcb_generate_id(connection);
		jmp setupScreenProfile;
	}









	setupScreenProfile:{
		#define SETUPSCREENPROFILE_VISUAL /*-*/ visual
		#define SETUPSCREENPROFILE_DEPTH /*--*/ depth
		#include "xcb/setupScreenProfile.hold"
		jmp createWindow;
	}









	createWindow:{
		struct{
			uint32 /*---------*/ backgroundColor;
			uint32 /*---------*/ borderColor;
			bool /*-----------*/ overrideRedirect;
			uint32 /*---------*/ eventMask;
			xcb_colormap_t /*-*/ colormap;
		} attribute;
		requestCheck(xcb_create_colormap_checked(connection, XCB_COLORMAP_ALLOC_NONE, colormap, (*screen).root, visual), "could not create colormap", XCB_NONE);
		attribute.backgroundColor /*--*/ = 0x00000000;
		attribute.borderColor /*------*/ = 0x00000000;
		attribute.overrideRedirect /*-*/ = true;
		attribute.eventMask /*--------*/ = XCB_EVENT_MASK_EXPOSURE;
		attribute.colormap /*---------*/ = colormap;



		requestCheck(xcb_create_window_checked(connection, depth, window, (*screen).root, x, y, width, height, 0, XCB_WINDOW_CLASS_INPUT_OUTPUT, visual, XCB_CW_BACK_PIXEL | XCB_CW_BORDER_PIXEL | XCB_CW_OVERRIDE_REDIRECT | XCB_CW_EVENT_MASK | XCB_CW_COLORMAP, &attribute.backgroundColor), "could not create window", XCB_NONE);









		{
			uint32 gcData[3];
			requestCheck(xcb_open_font_checked(connection, font, LITERAL_LENGTH("fixed"), "fixed"), "could not open font", XCB_NONE);
			*(gcData + 0) = foreground;
			*(gcData + 1) = background;
			*(gcData + 2) = font;
			requestCheck(xcb_create_gc_checked(connection, gc, window, XCB_GC_FOREGROUND | XCB_GC_BACKGROUND | XCB_GC_FONT, gcData), "could not create graphics context", XCB_NONE);
		}
		jmp acquireFontMetrics;
	}









	/*!
		add icccm and ewmh information to all windows
	*/









	/*!
		remove reply pointer - use a global that will be handled by the QUIT_DEC function
	*/
	acquireFontMetrics:{
		xcb_query_font_reply_t *reply = xcb_query_font_reply(connection, xcb_query_font(connection, font), NULL);
		if(reply){
			fontX      = (*reply).min_bounds.left_side_bearing;
			fontY      = (*reply).font_ascent;
			fontWidth  = (*reply).max_bounds.right_side_bearing - (*reply).min_bounds.left_side_bearing;
			fontHeight = (*reply).max_bounds.ascent + (*reply).max_bounds.descent;
			free(reply);
			reply = NULL;
		}
		jmp expressErrors;
	}









	expressErrors:{
		if(depth == 24){
			printError("could not use 32-bit depth, using 24-bit depth instead");
		}
		jmp setupSignal;
	}









	setupSignal:{
		#define Sigaction /*-*/ struct sigaction
		Sigaction s;
		s.sa_handler = quit;
		s.sa_flags = 0;
		sigemptyset(&s.sa_mask);
		sigaction(SIGUSR1, &s, NULL);
		#undef  Sigaction
		jmp eventLoop;
	}









	eventLoop:{
		xcb_flush(connection);
		free(event);
		event = NULL;
		jmp waitForEventLoop;
	}
	waitForEventLoop:{
		if((event = xcb_wait_for_event(connection))){
			jmp switchEvents;
		}
		if(xcb_connection_has_error(connection)){
			printConnectionError();
			jmp eventLoopExit;
		}
		jmp waitForEventLoop;
	}
	switchEvents:{
		#undef  XCB_RANDR_SCREEN_CHANGE_NOTIFY
		#define XCB_ONE /*------------------------*/ (1)
		#define XCB_RANDR_SCREEN_CHANGE_NOTIFY /*-*/ (89)
		printEvent();
		switch (*event).response_type & ~0x80 over
			to XCB_NONE: /*-----------------------*/ jmp errorEvent;
			to XCB_ONE: /*------------------------*/ jmp unexpectedEvent;
			to XCB_KEY_PRESS: /*------------------*/ jmp unexpectedEvent;
			to XCB_KEY_RELEASE: /*----------------*/ jmp unexpectedEvent;
			to XCB_BUTTON_PRESS: /*---------------*/ jmp unexpectedEvent;
			to XCB_BUTTON_RELEASE: /*-------------*/ jmp unexpectedEvent;
			to XCB_MOTION_NOTIFY: /*--------------*/ jmp unexpectedEvent;
			to XCB_ENTER_NOTIFY: /*---------------*/ jmp unexpectedEvent;
			to XCB_LEAVE_NOTIFY: /*---------------*/ jmp unexpectedEvent;
			to XCB_FOCUS_IN: /*-------------------*/ jmp unexpectedEvent;
			to XCB_FOCUS_OUT: /*------------------*/ jmp unexpectedEvent;
			to XCB_KEYMAP_NOTIFY: /*--------------*/ jmp unexpectedEvent;
			to XCB_EXPOSE: /*---------------------*/ jmp exposeEvent;
			to XCB_GRAPHICS_EXPOSURE: /*----------*/ jmp unexpectedEvent;
			to XCB_NO_EXPOSURE: /*----------------*/ jmp unexpectedEvent;
			to XCB_VISIBILITY_NOTIFY: /*----------*/ jmp unexpectedEvent;
			to XCB_CREATE_NOTIFY: /*--------------*/ jmp unexpectedEvent;
			to XCB_DESTROY_NOTIFY: /*-------------*/ jmp unexpectedEvent;
			to XCB_UNMAP_NOTIFY: /*---------------*/ jmp unexpectedEvent;
			to XCB_MAP_NOTIFY: /*-----------------*/ jmp unexpectedEvent;
			to XCB_MAP_REQUEST: /*----------------*/ jmp unexpectedEvent;
			to XCB_REPARENT_NOTIFY: /*------------*/ jmp unexpectedEvent;
			to XCB_CONFIGURE_NOTIFY: /*-----------*/ jmp unexpectedEvent;
			to XCB_CONFIGURE_REQUEST: /*----------*/ jmp unexpectedEvent;
			to XCB_GRAVITY_NOTIFY: /*-------------*/ jmp unexpectedEvent;
			to XCB_RESIZE_REQUEST: /*-------------*/ jmp unexpectedEvent;
			to XCB_CIRCULATE_NOTIFY: /*-----------*/ jmp unexpectedEvent;
			to XCB_CIRCULATE_REQUEST: /*----------*/ jmp unexpectedEvent;
			to XCB_PROPERTY_NOTIFY: /*------------*/ jmp unexpectedEvent;
			to XCB_SELECTION_CLEAR: /*------------*/ jmp unexpectedEvent;
			to XCB_SELECTION_REQUEST: /*----------*/ jmp unexpectedEvent;
			to XCB_SELECTION_NOTIFY: /*-----------*/ jmp unexpectedEvent;
			to XCB_COLORMAP_NOTIFY: /*------------*/ jmp unexpectedEvent;
			to XCB_CLIENT_MESSAGE: /*-------------*/ jmp unexpectedEvent;
			to XCB_MAPPING_NOTIFY: /*-------------*/ jmp eventLoop;
			to XCB_GE_GENERIC: /*-----------------*/ jmp unexpectedEvent;
			to XCB_RANDR_SCREEN_CHANGE_NOTIFY: /*-*/ jmp unexpectedEvent;
			off: /*-------------------------------*/ jmp unexpectedEvent;
		end
		#undef  XCB_RANDR_SCREEN_CHANGE_NOTIFY
		#undef  XCB_ONE
	}









	errorEvent:{
		genericError = (void *)event;
		printXCBError();
		genericError = NULL;
		jmp eventLoop;
	}









/*!
	maybe: add a counter so that the first expose happens and only the next ones are interrupted
*/
	exposeEvent:{



		#define PCLOSE_FAILURE /*-*/ (-1)



		FILE *file;
		char brightnessNameLeft[3];
		*(brightnessNameLeft + 0) = '-';
		*(brightnessNameLeft + 1) = '-';
		*(brightnessNameLeft + 2) = '-';
		received = false;
		if((file = popen("cat /sys/class/*/amdgpu_bl0/brightness", "r"))){
			char c;









			{
				int i = 0;
				loopo:{
					c = fgetc(file);
					if(c == '\n'){
						jmp loopoExit;
					}
					brightnessNameLeft[i] = c;
					++i;
					jmp loopo;
				}
				loopoExit:{}
			}
			if(brightnessNameLeft[1] == '-'){
				brightnessNameLeft[2] = brightnessNameLeft[0];
				brightnessNameLeft[1] = '0';
				brightnessNameLeft[0] = '0';
			}



			if(brightnessNameLeft[2] == '-'){
				brightnessNameLeft[2] = brightnessNameLeft[1];
				brightnessNameLeft[1] = brightnessNameLeft[0];
				brightnessNameLeft[0] = '0';
			}









			if(pclose(file) == PCLOSE_FAILURE){
				printError("could not close brightness information file");
			}
		}else{
			printError("could not open brightness information file");
		}



		#undef  PCLOSE_FAILURE








		xcb_put_image_checked(connection, XCB_IMAGE_FORMAT_Z_PIXMAP, window, gc, base.width, base.height, base.x, base.y, 0, depth, base.size, (void *)base.data);
		if(received) jmp prepareForAnotherExpose;
		xcb_image_text_8_checked(connection, LITERAL_LENGTH(name), window, gc, fontX + 10, fontY + 10 + 2 * fontHeight, name);
		if(received) jmp prepareForAnotherExpose;
		xcb_image_text_8_checked(connection, 3, window, gc, fontX + 10, fontY + 10 + 3 * fontHeight, brightnessNameLeft);
		if(received) jmp prepareForAnotherExpose;
		xcb_image_text_8_checked(connection, LITERAL_LENGTH(name), window, gc, fontX + 10, fontY + 10 + 4 * fontHeight, name);
		if(received) jmp prepareForAnotherExpose;
		xcb_image_text_8_checked(connection, 3, window, gc, fontX + 10, fontY + 10 + 5 * fontHeight, brightnessNameLeft);
		if(received) jmp prepareForAnotherExpose;
		xcb_flush(connection);
		if(received) jmp prepareForAnotherExpose;
		sleep(duration);
		if(received) jmp prepareForAnotherExpose;









		xcb_unmap_window(connection, window);
		xcb_flush(connection);



		jmp eventLoop;
	}
	prepareForAnotherExpose:{
		xcb_flush(connection);
		received = false;
		jmp exposeEvent;
	}
	unexpectedEvent:{
		printUnexpectedEvent();
		jmp eventLoop;
	}
	eventLoopExit:{
		free(event);
		event = NULL;
		jmp mainEmergencyExit;
	}
	mainEmergencyExit:{
		xcb_disconnect(connection);
		connection = NULL;
		ret 0;
	}
}
PRINTERROR_DEC{
	if(openErrorStream()){
		fprintf(errorStream, "%s: %s\n", programName, string);
		closeErrorStream();
	}
	ret;
}
OPENERRORSTREAM_DEC{
	ret !mustOpenErrorStream or (errorStream = fopen(errorPath, "a"));
}
CLOSEERRORSTREAM_DEC{
	if(mustOpenErrorStream and errorStream){
		fclose(errorStream);
		errorStream = NULL;
	}
	ret;
}
PRINTCONNECTIONERROR_DEC{
	if(openErrorStream()){
		#define PRINTCONNECTIONERROR_ERROR /*--*/ xcb_connection_has_error(connection)
		#define PRINTCONNECTIONERROR_STREAM /*-*/ errorStream
		#include "xcb/printConnectionError.hold"
		closeErrorStream();
	}
	ret;
}
REQUESTCHECK_DEC{
	if(!(genericError = xcb_request_check(connection, c))){
		ret;
	}
	if(errorCode != XCB_NONE and (*genericError).error_code == errorCode){
		printError(errorMessage);
	}else{
		printXCBError();
	}
	free(genericError);
	genericError = NULL;
	ret;
}
#if DEBUG
PRINTEVENT_DEC{
	#define PRINTEVENT_EVENT /*--*/ event
	#define PRINTEVENT_STREAM /*-*/ stdout
	#include "xcb/printEvent.hold"
	ret;
}
#endif
PRINTXCBERROR_DEC{
	if(openErrorStream()){
		#define PRINTXCBERROR_ERROR /*--*/ genericError
		#define PRINTXCBERROR_STREAM /*-*/ errorStream
		#include "xcb/printXCBError.hold"
		closeErrorStream();
	}
	ret;
}
#if DEBUG
PRINTUNEXPECTEDEVENT_DEC{
	if(openErrorStream()){
		#define PRINTUNEXPECTEDEVENT_EVENT /*--*/ event
		#define PRINTUNEXPECTEDEVENT_STREAM /*-*/ errorStream
		#include "xcb/printUnexpectedEvent.hold"
		closeErrorStream();
	}
	ret;
}
#endif

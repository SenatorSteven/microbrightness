#define LOADTEXTURE_DEC /*---*/ local Texture loadTexture(const char *const path)

#define LITERAL_LENGTH(l) /*-*/ (sizeof(l) - 1)

time_t seconds;

LOADTEXTURE_DEC{
	Texture texture;
	FILE *file;
	uint offset;
	uint8 data[26];
	if(!(file = fopen(path, "rb"))){
		printError("could not open texture file");
		jmp retFailure;
	}
	if(fread(data, 1, 26, file) != 26){
		printError("could not read texture file data");
		jmp retFailure;
	}
	if(*data != 'B' or *(data + 1) != 'M'){
		printError("texture file is not bitmap");
		jmp retFailure;
	}
	offset         = *(uint32 *)(data + 10);
	texture.width  = *(uint32 *)(data + 18);
	texture.height = *(uint32 *)(data + 22);
	texture.size   = *(uint32 *)(data +  2) - offset;
	fseek(file, offset, SEEK_SET);
	if(!(texture.data = malloc(texture.size * sizeof(uint8)))){
		printError("texture file is not bitmap");
		jmp retFailure;
	}
	{
		const uint width = texture.width * 4;
		uint8 *start = texture.data;
		uint8 *current = start + texture.size - width;
		readRowLoop:{
			if(fread(current, 1, width, file) != width){
				printError("could not read texture file data");
				jmp retFailure;
			}
			if((current -= width) >= start){
				jmp readRowLoop;
			}
		}
	}
	fclose(file);
	file = NULL;
	ret texture;
	retFailure:{
		texture.width  = 0;
		texture.height = 0;
		texture.size   = 0;
		texture.data   = NULL;
		ret texture;
	}
}
void realApplyTexture(Texture source, Texture destination){
	bool replace = true;
	int x = 0;
	while(x < source.width){
		int y = 0;
		while(y < source.height){
			if(*(uint32 *)source.data){
				if(replace){
					*(uint32 *)destination.data = *(uint32 *)source.data;
				}else{
					*(uint32 *)destination.data = 0x00000000;
				}
			}
			destination.data = (uint32 *)destination.data + 1;
			source     .data = (uint32 *)source     .data + 1;
			inc y;
		}
		inc x;
	}
	ret;
}
void realApplyTexture1(Texture source, Texture destination){
	int x = 0;
	while(x < source.width){
		int y = 0;
		while(y < source.height){
			if(*(uint32 *)source.data){
				*(uint32 *)destination.data = *(uint32 *)source.data;
			}
			destination.data = (uint32 *)destination.data + 1;
			source     .data = (uint32 *)source     .data + 1;
			inc y;
		}
		inc x;
	}
	ret;
}
void realApplyTexture1WithXY(int sourceX, int sourceY, int destinationX, int destinationY, Texture source, Texture destination){
	uint32 *sourceData = (uint32 *)source.data;
	uint32 *destinationData = (uint32 *)destination.data;
	while(sourceX < source.width){
		int sy = sourceY;
		int dy = destinationY;
		while(sy < source.height){
			if(*(sourceData + sy * source.width + sourceX)){
				*(destinationData + dy * destination.width + destinationX) = *(sourceData + sy * source.width + sourceX);
			}
			inc dy;
			inc sy;
		}
		inc sourceX;
		inc destinationX;
	}
	ret;
}
void filterTexture(Texture filter, Texture destination){
	int x = 0;
	while(x < filter.width){
		int y = 0;
		while(y < filter.height){
			if(!*(uint32 *)filter.data){
				*(uint32 *)destination.data = 0x00000000;
			}
			destination.data = (uint32 *)destination.data + 1;
			filter     .data = (uint32 *)filter     .data + 1;
			inc y;
		}
		inc x;
	}
	ret;
}









